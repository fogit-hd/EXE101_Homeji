# Production trên Render Web Service (khuyến nghị):
#   để TRỐNG — browser gọi /api cùng origin, server proxy sang Fly (không cần CORS).
# Production Static Site (không có proxy): bắt buộc set URL đầy đủ + backend phải CORS.
#   VITE_API_BASE_URL=https://homeji-be.onrender.com
VITE_API_BASE_URL=

# Target cho scripts/serve-prod.mjs (chỉ runtime trên Web Service, không cần VITE_)
# API_PROXY_TARGET=https://homeji-be.onrender.com

# Maps JavaScript API — chỉ dùng API chính thức từ Google (maps.googleapis.com).
# Không dùng wrapper bên thứ ba (@vis.gl, etc.).
# Google Cloud project:
#   • Maps JavaScript API  (bắt buộc)
#   • Places API           (autocomplete / trường gần đây)
#   • Geocoding API        (địa chỉ → tọa độ)
# Map Management → Map ID kiểu Vector (khuyến nghị WebGL mượt)
VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# Cloud Map ID (Vector) — Advanced Markers + Light/Dark styles
# VITE_GOOGLE_MAP_ID=your_cloud_map_id
