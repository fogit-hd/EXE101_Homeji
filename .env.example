# Production trên Render Web Service (khuyến nghị):
#   để TRỐNG — browser gọi /api cùng origin, server proxy sang Fly (không cần CORS).
# Production Static Site (không có proxy): bắt buộc set URL đầy đủ + backend phải CORS.
#   VITE_API_BASE_URL=https://homeji-api.fly.dev
VITE_API_BASE_URL=

# Target cho scripts/serve-prod.mjs (chỉ runtime trên Web Service, không cần VITE_)
# API_PROXY_TARGET=https://homeji-api.fly.dev

# Maps JavaScript API — project exe101-homeji trên Google Cloud:
#   • Maps JavaScript API  (bắt buộc — hiển thị bản đồ)
#   • Places API           (tùy chọn — autocomplete địa chỉ)
#   • Geocoding API        (tùy chọn — chuyển địa chỉ → tọa độ)
# Credentials → API key → Application restrictions → HTTP referrers:
#   http://localhost:5173/*
#   https://exe101-homeji.onrender.com/*
# API restrictions: Don't restrict (dev) HOẶC tick Maps JavaScript API (+ Places, Geocoding nếu cần)
VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# Map ID (Google Cloud → Maps → Map Management). Để trống = DEMO_MAP_ID
# VITE_GOOGLE_MAP_ID=
