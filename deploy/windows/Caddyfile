{
    # Keep Caddy's automatic HTTPS available when PublicHost is replaced with a DNS name.
    # Set HOMEJI_PUBLIC_HOST to the DNS name used by this Windows deployment.
    auto_https disable_redirects
}

{$HOMEJI_PUBLIC_HOST} {
    encode gzip

    # SignalR and API go directly to ASP.NET Core; Caddy handles WebSocket upgrades.
    reverse_proxy /api/* 127.0.0.1:8080
    reverse_proxy /hubs/* 127.0.0.1:8080

    # The FE process serves dist/ and handles SPA fallback.
    reverse_proxy 127.0.0.1:3000
}
