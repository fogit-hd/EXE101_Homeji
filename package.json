{
  "name": "exe-homeji-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:clean": "node -e \"try{require('node:fs').rmSync('node_modules/.vite',{recursive:true,force:true})}catch(e){}\" && vite --force",
    "build": "tsc -b && vite build",
    "start": "serve -s dist -l tcp://0.0.0.0:$PORT",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vis.gl/react-google-maps": "^1.9.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "serve": "^14.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/google.maps": "^3.65.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  }
}
